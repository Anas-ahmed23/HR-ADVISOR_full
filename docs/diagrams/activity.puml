@startuml GradVoice_ActivityDiagram

' ── Theme ─────────────────────────────────────────────────────
skinparam backgroundColor   White
skinparam defaultFontName   "Arial"
skinparam defaultFontSize   11
skinparam shadowing         false
skinparam handwritten       false

skinparam activity {
  BackgroundColor           White
  BorderColor               #1F3A5F
  BorderThickness           1.5
  FontColor                 #1F3A5F
  FontSize                  11
  ArrowColor                #1F3A5F
  StartColor                #1F3A5F
  EndColor                  #1F3A5F
  DiamondBackgroundColor    White
  DiamondBorderColor        #1F3A5F
}

skinparam swimlane {
  BorderColor               #1F3A5F
  BorderThickness           1.5
  TitleFontColor            #1F3A5F
  TitleFontSize             12
  TitleFontStyle            bold
  BackgroundColor           White
}

skinparam Arrow {
  Color                     #1F3A5F
  FontColor                 #1F3A5F
}

' ── Swimlanes ────────────────────────────────────────────────
|Student / Candidate|
start

:Select Job Description\nfrom 134 curated JDs (12 categories);
:Upload CV file (PDF or DOCX);
:Submit for analysis;

|GradVoice Frontend (Next.js)|
:Validate file inputs;
:POST /api/analyze_cv → Flask backend (port 5001);

|GradVoice Backend — hr_analyzer.py|
:Save CV and JD to uploads/;
:Extract raw text from CV PDF;
:Extract raw text from Job Description;
:Run Flair NER — detect skills,\nexperience, education entities;
:Build structured prompt\n(candidate profile + JD requirements\n+ skill keyword dictionaries);

|Azure OpenAI (GPT-4.1)|
:Score candidate across 8 dimensions\n(Skills Match, Experience Depth, Education,\nLeadership, Cultural Fit, ATS Compliance, etc.);
:Return structured JSON\n(scores, gaps, recommendations, insights);

|GradVoice Backend — hr_analyzer.py|
:Parse and validate LLM JSON response;
:Detect skill gaps\n(matched skills vs. required skills);
:Generate candidate advice and voice_agent_facts;
:Build retrieval_chunks → persist to HR KB;
:Return full analysis JSON to frontend;

|GradVoice Frontend (Next.js)|
:Store result in React Context + localStorage\n(key: gradvoice_analysis_v1);
:Set isComplete = true (unlocks Voice Agent route);
:Render ATS Dashboard:\n  • Animated score ring\n  • 8-dimension breakdown\n  • Matched / Missing Skills\n  • Candidate Advice & Insights;

|Student / Candidate|
if (Download PDF report?) then (yes)
  :jsPDF generates and downloads\nhr-advisor-{job-title}-{timestamp}.pdf;
endif

if (Proceed to Voice Screening?) then (yes)

  :Grant microphone access;
  :Begin speaking to Voice Agent;

  |GradVoice Frontend (Next.js)|
  :Open RTCPeerConnection → agent.py (port 5000);
  :Stream microphone audio via WebRTC;

  |GradVoice Backend — agent.py|
  :Load analysis context from\nruntime/voice_context/current_context.json;
  :Receive inbound WebRTC audio track;
  :Azure STT (gpt-4o-transcribe)\n→ transcribed text;
  :Append utterance to conversation history;

  |Azure OpenAI (GPT-4.1)|
  :Generate interview response\ngrounded in analysis context;

  |GradVoice Backend — agent.py|
  :Sanitize response text (sanitize_tts_text());
  :Azure TTS (gpt-4o-mini-tts, voice: alloy)\n→ audio stream;

  |GradVoice Frontend (Next.js)|
  :Play audio response;
  :Update AI Insights Engine display\n(Communication Clarity, Ownership Signals,\nRole-fit Topics);

  |Student / Candidate|
  if (Continue or interrupt?) then (continue)
    -> ;
  else (end session)
    |GradVoice Frontend (Next.js)|
    :Close RTCPeerConnection;
  endif

else (no)
endif

stop

@enduml
