@startuml GradVoice_UseCaseDiagram

!pragma layout smetana

' ── Theme ─────────────────────────────────────────────────────
skinparam backgroundColor     White
skinparam actorStyle          awesome
skinparam defaultFontName     "Arial"
skinparam defaultFontSize     12
skinparam shadowing           false
skinparam handwritten         false
skinparam roundcorner         8

skinparam usecase {
  BackgroundColor   #EFF6FF
  BorderColor       #1E40AF
  BorderThickness   1.5
  FontColor         #1E3A5F
  FontSize          12
}

skinparam actor {
  BorderColor       #1E3A5F
  BackgroundColor   White
  FontColor         #1E3A5F
  FontSize          12
}

skinparam rectangle {
  BorderColor       #1E3A5F
  BorderThickness   2.5
  FontStyle         bold
  FontSize          13
  FontColor         White
  BackgroundColor   #1E3A5F
}

skinparam Arrow {
  Color             #1E3A5F
  FontColor         #374151
  FontSize          10
}

left to right direction

' ── Actors (ordered top-to-bottom to match their use cases) ──
actor "Student /\nCandidate" as student
actor "Career\nCounselor"    as counselor
actor "System\nAdmin"        as admin

' ── System Boundary ───────────────────────────────────────────
rectangle "GradVoice Application" {

  ' CV Analysis flow
  usecase "Select Job Description\n(from 134 curated JDs)"   as UC_JD
  usecase "Upload CV"                                         as UC_CV
  usecase "Analyze CV vs Job Description"                     as UC_EVAL

  ' Results (to the right of EVAL via include)
  usecase "View Score & Skill Gaps\n(8-Dimension Breakdown)"  as UC_SCORE
  usecase "Get Role Recommendations\n& Candidate Advice"      as UC_RECO

  ' Voice — below analysis
  usecase "AI Voice Screening Interview"                      as UC_VOICE

  ' Output
  usecase "Download PDF Report"                               as UC_REPORT

  ' History / Admin — further down
  usecase "View Analysis History"                             as UC_HIST
  usecase "Ingest / Curate HR Knowledge Base"                 as UC_INGEST
  usecase "Monitor Metrics & Logs"                            as UC_MONITOR

  ' ── Layout: force strict top-to-bottom column on the left ──
  UC_JD     -[hidden]down-> UC_CV
  UC_CV     -[hidden]down-> UC_EVAL
  UC_EVAL   -[hidden]down-> UC_VOICE
  UC_VOICE  -[hidden]down-> UC_REPORT
  UC_REPORT -[hidden]down-> UC_HIST
  UC_HIST   -[hidden]down-> UC_INGEST
  UC_INGEST -[hidden]right-> UC_MONITOR

  ' ── Layout: push include targets to the right of EVAL ─────
  UC_EVAL  -[hidden]right-> UC_SCORE
  UC_SCORE -[hidden]down->  UC_RECO

}

' ── External Systems (right side) ────────────────────────────
rectangle "Azure OpenAI\n(GPT-4.1  ·  GPT-4o STT/TTS)" as Azure
rectangle "HR Knowledge Base\n(Document Store + Vector DB)" as KB

' ── Actor Associations ────────────────────────────────────────
student   --> UC_JD
student   --> UC_CV
student   --> UC_EVAL
student   --> UC_VOICE
student   --> UC_REPORT

counselor --> UC_HIST

admin     --> UC_INGEST
admin     --> UC_MONITOR
admin     --> UC_HIST

' ── Include / Extend ──────────────────────────────────────────
UC_EVAL  ..>  UC_SCORE  : «include»
UC_EVAL  ..>  UC_RECO   : «include»
UC_VOICE ..>  UC_EVAL   : «extend»

' ── External System Interactions ──────────────────────────────
UC_EVAL  ..>  Azure : GPT-4.1 structured scoring
UC_VOICE ..>  Azure : STT / LLM / TTS
UC_EVAL  ..>  KB    : writes results & embeddings
UC_VOICE ..>  KB    : reads analysis context
UC_REPORT ..> KB    : reads

@enduml
